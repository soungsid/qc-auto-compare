# Copy this file to .env and fill in your values

# Database
DB_USER=qc_auto_user
DB_PASSWORD=supersecret

# Backend
SECRET_KEY=change-me-in-production
DEBUG=false
CORS_ORIGINS=http://localhost:3000

# Crawler
CRAWL_DELAY_MIN=2
CRAWL_DELAY_MAX=5
CRAWLER_BATCH_SIZE=50

# Scheduler
FULL_CRAWL_INTERVAL_HOURS=12
STALE_VEHICLE_HOURS=72
PRICE_ALERT_THRESHOLD_PCT=5
