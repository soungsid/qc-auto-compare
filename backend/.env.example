# Application
APP_ENV=development
SECRET_KEY=change-me-in-production
DEBUG=true

# Database (PostgreSQL en prod, SQLite en dev local)
DATABASE_URL=sqlite+aiosqlite:///./qc_auto.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/qc_auto
DB_NAME=qc_auto
DB_USER=qc_auto_user
DB_PASSWORD=supersecret

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Crawler
BACKEND_INGEST_URL=http://localhost:8000/api/ingest/batch
CRAWL_DELAY_MIN=2
CRAWL_DELAY_MAX=5
CRAWLER_BATCH_SIZE=50
# Docker Compose project name (used by /api/crawl/run to find the crawler image)
COMPOSE_PROJECT_NAME=qc-auto-compare-org

# Scheduler
FULL_CRAWL_INTERVAL_HOURS=12
STALE_VEHICLE_HOURS=72
PRICE_ALERT_THRESHOLD_PCT=5

# Traefik / Deployment
DOMAIN=auto.canadaquebec.ca
FRONTEND_PORT=3000
BACKEND_PORT=8000
TRAEFIK_TLS=true
TRAEFIK_CERT_RESOLVER=myhttpchallenge
